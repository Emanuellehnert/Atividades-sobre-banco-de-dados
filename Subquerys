-- ==============================================================================
-- 1. CRIAÇÃO DA TABELA E INSERÇÃO DOS DADOS
-- ==============================================================================

CREATE TABLE IF NOT EXISTS Itens_Estoque (
    idItem INT NOT NULL AUTO_INCREMENT,
    descricaoItem VARCHAR(200),
    setorItem VARCHAR(200),
    precoVendaItem DECIMAL(9,2),
    estoqueItem INT,
    PRIMARY KEY (idItem)
); 

